# ==========================================
# AeroScope 环境变量配置
# 部署步骤：
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入真实值
#   3. .env 已加入 .gitignore，不会被提交
# ==========================================

# --- Supabase 数据库 ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- 阿里云 OSS 对象存储 ---
ALIBABA_ACCESS_KEY_ID=your-access-key-id
ALIBABA_ACCESS_KEY_SECRET=your-access-key-secret
OSS_PUBLIC_BUCKET=aeroscope-public
OSS_PRIVATE_BUCKET=aeroscope-secure
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com

# --- LLM API (AI 采编) ---
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- 其他 ---
# SITE_URL=https://www.aeroscope.cn
# ADMIN_EMAIL=admin@aeroscope.cn
